# ── Kie.ai ────────────────────────────────────────────────────────────────────
# Get your token at https://kie.ai/api-key
KIE_API_TOKEN=

# Public URL where kie.ai POSTs job completion results (webhook).
# Must be reachable from the internet.
# Local dev: use ngrok → ngrok http 3000
# Production: your deployed domain, e.g. https://your-app.vercel.app
CALLBACK_BASE_URL=

# ── Supabase ──────────────────────────────────────────────────────────────────
# Settings → API in your Supabase project dashboard
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# ── Cloudflare R2 ─────────────────────────────────────────────────────────────
# Account ID: Cloudflare dashboard sidebar
R2_ACCOUNT_ID=
# API token: R2 → Manage R2 API Tokens → Create API Token (Object Read & Write)
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=
# Public CDN URL — enable public access on the bucket first
R2_PUBLIC_URL=

# ── Azure OpenAI (optional) ───────────────────────────────────────────────────
# Only needed if routing models through Azure AI Foundry instead of Kie.ai
AZURE_API_KEY=
